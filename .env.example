# Outscraper API key (required for real data)
# Get your free key at: https://app.outscraper.com/account/api
# Free tier: 500 reviews/month
OUTSCRAPER_API_KEY=your-outscraper-api-key

# Server
PORT=8080
LOG_LEVEL=info
NODE_ENV=development

# Set to true to use mock data (no API key needed)
ENABLE_MOCK_MODE=false
